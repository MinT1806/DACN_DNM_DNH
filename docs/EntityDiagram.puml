@startuml EntityDiagram_ABCEnglish

title Entity Relationship Diagram - ABC English Learning Platform
skinparam linetype ortho
skinparam shadowing false

' ==================== USER & PROFILE ====================
entity "users" as users {
    * **id** : BIGINT <<PK>>
    --
    * username : VARCHAR(255) <<UNIQUE, NOT NULL>>
    * email : VARCHAR(255) <<UNIQUE, NOT NULL>>
    * password : VARCHAR(255) <<NOT NULL>>
    full_name : VARCHAR(255)
    avatar : VARCHAR(255)
    age_group : VARCHAR(50)
    placement_test_completed : BOOLEAN = false
    role : ENUM('STUDENT','TEACHER','ADMIN','MENTOR')
    level : ENUM('A1','A2','B1','B2','C1','C2')
    total_points : INT = 0
    created_at : DATETIME
}

entity "user_stats" as user_stats {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK, UNIQUE>>
    --
    total_xp : INT = 0
    level : ENUM('A1','A2','B1','B2','C1','C2')
    current_streak : INT = 0
    courses_enrolled : INT = 0
    courses_completed : INT = 0
    lessons_completed : INT = 0
    exercises_completed : INT = 0
    vocabulary_learned : INT = 0
    speaking_sessions : INT = 0
    writing_submissions : INT = 0
    forum_posts : INT = 0
    forum_replies : INT = 0
    total_study_minutes : INT = 0
    weekly_study_minutes : INT = 0
    monthly_study_minutes : INT = 0
    grammar_score : DOUBLE = 0.0
    vocabulary_score : DOUBLE = 0.0
    speaking_score : DOUBLE = 0.0
    listening_score : DOUBLE = 0.0
    reading_score : DOUBLE = 0.0
    writing_score : DOUBLE = 0.0
    overall_accuracy : DOUBLE = 0.0
    updated_at : DATETIME
}

entity "user_streaks" as user_streaks {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK, UNIQUE>>
    --
    current_streak : INT = 0
    longest_streak : INT = 0
    last_activity_date : DATE
    weekly_goal : INT = 7
    weekly_progress : INT = 0
    total_active_days : INT = 0
}

entity "social_accounts" as social_accounts {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    --
    provider : ENUM('GOOGLE','FACEBOOK') <<NOT NULL>>
    provider_user_id : VARCHAR(255) <<UNIQUE, NOT NULL>>
    access_token : VARCHAR(1000)
    refresh_token : VARCHAR(1000)
    email : VARCHAR(255)
    full_name : VARCHAR(255)
    avatar : VARCHAR(255)
    linked_at : DATETIME
}

' ==================== COURSES & LESSONS ====================
entity "courses" as courses {
    * **id** : BIGINT <<PK>>
    --
    title : VARCHAR(255)
    description : TEXT
    level : ENUM('A1','A2','B1','B2','C1')
    thumbnail : VARCHAR(255)
    instructor : VARCHAR(255)
    total_lessons : INT
    enrolled_count : INT = 0
    rating : DOUBLE = 0.0
    created_at : DATETIME
}

entity "chapters" as chapters {
    * **id** : BIGINT <<PK>>
    * course_id : BIGINT <<FK>>
    --
    title : VARCHAR(255) <<NOT NULL>>
    description : TEXT
    order_index : INT
    total_lessons : INT
    created_at : DATETIME
}

entity "lessons" as lessons {
    * **id** : BIGINT <<PK>>
    * chapter_id : BIGINT <<FK>>
    --
    title : VARCHAR(255) <<NOT NULL>>
    description : TEXT
    type : ENUM('VIDEO','AUDIO','READING','EXERCISE','QUIZ')
    order_index : INT
    video_url : VARCHAR(500)
    audio_url : VARCHAR(500)
    pdf_url : VARCHAR(500)
    content : TEXT
    duration_minutes : INT
    xp_reward : INT = 10
    created_at : DATETIME
}

entity "lesson_progress" as lesson_progress {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    * lesson_id : BIGINT <<FK>>
    --
    completed : BOOLEAN = false
    progress_percent : INT = 0
    xp_earned : INT = 0
    completed_at : DATETIME
    last_accessed_at : DATETIME
    created_at : DATETIME
    <<UNIQUE: (user_id, lesson_id)>>
}

entity "course_enrollments" as course_enrollments {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    * course_id : BIGINT <<FK>>
    --
    progress_percent : INT = 0
    lessons_completed : INT = 0
    enrolled_at : DATETIME
    completed_at : DATETIME
    <<UNIQUE: (user_id, course_id)>>
}

entity "certificates" as certificates {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    * course_id : BIGINT <<FK>>
    --
    certificate_number : VARCHAR(255) <<UNIQUE, NOT NULL>>
    user_name : VARCHAR(255)
    course_name : VARCHAR(255)
    completion_date : DATETIME
    final_score : DOUBLE = 0.0
    total_lessons : INT = 0
    lessons_completed : INT = 0
    pdf_url : TEXT
    is_issued : BOOLEAN = false
    issued_at : DATETIME
    created_at : DATETIME
    <<UNIQUE: (user_id, course_id)>>
}

' ==================== EXERCISES & ASSESSMENT ====================
entity "exercises" as exercises {
    * **id** : BIGINT <<PK>>
    --
    title : VARCHAR(255)
    description : TEXT
    type : ENUM('MULTIPLE_CHOICE','FILL_IN_BLANK','WRITING',
              'SPEAKING','READING','LISTENING')
    skill : ENUM('WRITING','SPEAKING','READING','LISTENING','GRAMMAR','VOCABULARY')
    level : ENUM('A1','A2','B1','B2','C1')
    topic : VARCHAR(255)
    content : TEXT
    answer_key : TEXT
    explanation : TEXT
    created_at : DATETIME
}

entity "exercise_results" as exercise_results {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    * exercise_id : BIGINT <<FK>>
    --
    skill_type : ENUM('GRAMMAR','VOCABULARY','WRITING','SPEAKING','READING','LISTENING')
    user_answer : TEXT
    score : DOUBLE
    feedback : TEXT
    suggestions : TEXT
    completed_at : DATETIME
}

entity "placement_tests" as placement_tests {
    * **id** : BIGINT <<PK>>
    --
    title : VARCHAR(255) <<NOT NULL>>
    description : TEXT
    target_level : ENUM('A1','A2','B1','B2','C1') = 'A1'
    total_questions : INT = 0
    time_limit_minutes : INT = 30
    is_active : BOOLEAN = true
    created_at : DATETIME
}

entity "placement_questions" as placement_questions {
    * **id** : BIGINT <<PK>>
    * placement_test_id : BIGINT <<FK>>
    --
    question : VARCHAR(255) <<NOT NULL>>
    skill_type : ENUM('GRAMMAR','VOCABULARY','LISTENING','READING','SPEAKING','WRITING')
    level : ENUM('A1','A2','B1','B2','C1')
    options : JSON
    correct_answer : TEXT <<NOT NULL>>
    explanation : TEXT
    passage : TEXT
    audio_url : VARCHAR(500)
    image_url : VARCHAR(500)
    order_index : INT = 0
    points : INT = 1
}

' ==================== VOCABULARY ====================
entity "vocabulary_words" as vocabulary_words {
    * **id** : BIGINT <<PK>>
    --
    word : VARCHAR(255) <<NOT NULL>>
    pronunciation : VARCHAR(255) <<NOT NULL>>
    translation : VARCHAR(255) <<NOT NULL>>
    definition : TEXT
    example : TEXT
    example_translation : TEXT
    part_of_speech : VARCHAR(50)
    level : ENUM('A1','A2','B1','B2','C1')
    category : VARCHAR(100)
    audio_url : VARCHAR(500)
    image_url : VARCHAR(500)
    created_at : DATETIME
    is_active : BOOLEAN = true
}

entity "vocabulary_sets" as vocabulary_sets {
    * **id** : BIGINT <<PK>>
    --
    name : VARCHAR(255)
    description : TEXT
    thumbnail : VARCHAR(255)
    level : ENUM('A1','A2','B1','B2','C1')
    category : VARCHAR(100)
    created_by : VARCHAR(255)
    word_count : INT = 0
    created_at : DATETIME
    is_public : BOOLEAN = true
}

entity "user_vocabulary_progress" as user_vocabulary_progress {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    * vocabulary_word_id : BIGINT <<FK>>
    --
    mastery_level : INT = 0 (0-5)
    next_review_date : DATE
    last_review_date : DATE
    review_count : INT = 0
    correct_count : INT = 0
    incorrect_count : INT = 0
    ease_factor : DOUBLE = 2.5 (SM-2)
    created_at : DATETIME
    <<UNIQUE: (user_id, vocabulary_word_id)>>
}

' ==================== GAMIFICATION ====================
entity "daily_challenges" as daily_challenges {
    * **id** : BIGINT <<PK>>
    --
    challenge_date : DATE <<NOT NULL>>
    type : ENUM('VOCAB_QUIZ','LISTENING','SPEAKING_SHADOWING',
               'GRAMMAR_SPRINT','READING_SPEED','MIXED')
    title : VARCHAR(255) <<NOT NULL>>
    description : TEXT
    content : JSON
    level : ENUM('A1','A2','B1','B2','C1')
    xp_reward : INT = 20
    target_goal : INT = 5
    is_active : BOOLEAN = true
    created_at : DATETIME
}

entity "user_daily_progress" as user_daily_progress {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    * challenge_id : BIGINT <<FK>>
    --
    challenge_date : DATE <<NOT NULL>>
    current_progress : INT = 0
    completed : BOOLEAN = false
    claimed : BOOLEAN = false
    score : INT
    time_spent_seconds : INT
    xp_earned : INT
    completed_at : DATETIME
    <<UNIQUE: (user_id, challenge_date)>>
}

entity "badges" as badges {
    * **id** : BIGINT <<PK>>
    --
    name : VARCHAR(255) <<NOT NULL>>
    description : TEXT
    icon : VARCHAR(255)
    color : VARCHAR(50)
    type : ENUM('STREAK','MASTERY','COURSE','SOCIAL','SPECIAL')
    xp_reward : INT = 50
    is_active : BOOLEAN = true
}

entity "user_badges" as user_badges {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    * badge_id : BIGINT <<FK>>
    --
    earned_at : DATETIME
    note : VARCHAR(500)
    <<UNIQUE: (user_id, badge_id)>>
}

' ==================== COMMUNICATION ====================
entity "chat_messages" as chat_messages {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    --
    role : ENUM('USER','ASSISTANT')
    content : TEXT <<NOT NULL>>
    type : ENUM('SCORING','EXERCISE','CHATBOT','GUIDANCE')
    created_at : DATETIME
}

entity "forum_posts" as forum_posts {
    * **id** : BIGINT <<PK>>
    * author_id : BIGINT <<FK>>
    * mentor_id : BIGINT <<FK>> <<NULL>>
    --
    title : VARCHAR(255)
    content : TEXT <<NOT NULL>>
    category : ENUM('GRAMMAR','VOCABULARY','SPEAKING','LISTENING',
                   'READING','WRITING','IELTS','TOEIC','GENERAL')
    level : ENUM('A1','A2','B1','B2','C1','ALL')
    tags : VARCHAR(255)
    view_count : INT = 0
    like_count : INT = 0
    comment_count : INT = 0
    answer_count : INT = 0
    is_pinned : BOOLEAN = false
    solved : BOOLEAN = false
    created_at : DATETIME
    updated_at : DATETIME
}

entity "forum_comments" as forum_comments {
    * **id** : BIGINT <<PK>>
    * post_id : BIGINT <<FK>>
    * author_id : BIGINT <<FK>>
    * parent_id : BIGINT <<FK>> <<NULL>>
    --
    content : TEXT <<NOT NULL>>
    like_count : INT = 0
    is_mentor_reply : BOOLEAN = false
    accepted_answer : BOOLEAN = false
    created_at : DATETIME
    updated_at : DATETIME
}

entity "mentor_assignments" as mentor_assignments {
    * **id** : BIGINT <<PK>>
    * mentor_id : BIGINT <<FK>>
    * student_id : BIGINT <<FK>>
    --
    notes : VARCHAR(500)
    learning_goal : TEXT
    assigned_at : DATETIME
    active : BOOLEAN = true
}

entity "mentor_messages" as mentor_messages {
    * **id** : BIGINT <<PK>>
    * assignment_id : BIGINT <<FK>>
    * sender_id : BIGINT <<FK>>
    * receiver_id : BIGINT <<FK>>
    --
    content : TEXT <<NOT NULL>>
    seen : BOOLEAN = false
    seen_at : DATETIME
    created_at : DATETIME
}

entity "notifications" as notifications {
    * **id** : BIGINT <<PK>>
    * user_id : BIGINT <<FK>>
    --
    type : ENUM('STUDY_REMINDER','MENTOR_MESSAGE','BADGE_EARNED',
               'LEVEL_UP','COURSE_ENROLLMENT','FORUM_REPLY',
               'ASSIGNMENT_DUE','SYSTEM')
    title : VARCHAR(255)
    message : TEXT
    link : VARCHAR(500)
    read : BOOLEAN = false
    is_email_sent : BOOLEAN = false
    created_at : DATETIME
}

' ==================== RELATIONSHIPS ====================

users ||--|| user_stats : has
users ||--|| user_streaks : has
users ||--o{ social_accounts : links
users ||--o{ exercise_results : submits
users ||--o{ course_enrollments : enrolls
users ||--o{ lesson_progress : completes
users ||--o{ user_vocabulary_progress : learns
users ||--o{ user_badges : earns
users ||--o{ user_daily_progress : completes
users ||--o{ chat_messages : sends
users ||--o{ forum_posts : creates
users ||--o{ forum_comments : adds
users ||--o{ mentor_assignments : mentors (1 mentor - N students)
users ||--o{ mentor_assignments : assigned_to (1 student - N mentors)
users ||--o{ mentor_messages : sends_as_sender
users ||--o{ mentor_messages : receives_as_receiver
users ||--o{ notifications : receives

courses ||--o{ chapters : contains
courses ||--o{ course_enrollments : enrolls
courses ||--o{ certificates : issues

chapters ||--o{ lessons : includes

lessons ||--o{ lesson_progress : tracks

exercises ||--o{ exercise_results : has

placement_tests ||--o{ placement_questions : includes

vocabulary_words ||--o{ user_vocabulary_progress : tracks

vocabulary_sets ||--o{ vocabulary_words : contains

daily_challenges ||--o{ user_daily_progress : has

badges ||--o{ user_badges : has

forum_posts ||--o{ forum_comments : contains
forum_comments ||--o{ forum_comments : nested_replies

mentor_assignments ||--o{ mentor_messages : has

@enduml

