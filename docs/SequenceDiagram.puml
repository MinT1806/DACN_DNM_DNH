@startuml SequenceDiagram_JWTAuth

title Sequence Diagram - JWT Authentication Filter

actor Client
participant "AuthTokenFilter" as ATF
participant "JwtUtils" as JWT
participant "UserDetailsServiceImpl" as UDS
participant "SecurityContextHolder" as SCH
participant "Controller" as CTRL

Client -> ATF : HTTP Request with\nAuthorization: Bearer <token>
activate ATF

ATF -> ATF : parseJwt(request)\nextract token from header

alt Token exists
    ATF -> JWT : validateJwtToken(token)
    activate JWT
    JWT --> ATF : true/false
    deactivate JWT

    alt Token valid
        ATF -> JWT : getUsernameFromJwtToken(token)
        activate JWT
        JWT --> ATF : username
        deactivate JWT

        ATF -> UDS : loadUserByUsername(username)
        activate UDS
        UDS --> ATF : UserDetails (with ROLE_xxx)
        deactivate UDS

        ATF -> SCH : setAuthentication(token)
        activate SCH
        SCH --> ATF
        deactivate SCH
    end
end

ATF -> CTRL : filterChain.doFilter(request, response)
activate CTRL
CTRL --> Client : HTTP Response
deactivate CTRL
deactivate ATF

@enduml

