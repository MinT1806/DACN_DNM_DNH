else recommendedLevel không hợp lệ
    AS -> AS : inferLevel(correctAnswers, totalQuestions)
    note right : ≥85%→C1, ≥70%→B2, ≥55%→B1, ≥40%→A2, <40%→A1
end

AS -> AS : user.setLevel(level)\nuser.setPlacementTestCompleted(true)

AS -> UR : save(user)
activate UR
UR -> DB : UPDATE users SET level, placement_test_completed
DB --> UR : updated
UR --> AS : User
deactivate UR

AS --> PTC : AuthResponse (with updated level)
deactivate AS

PTC --> Student : 200 OK\n{id, username, level, placementTestCompleted: true, ...}
deactivate PTC

